    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "nanoid": "^5.0.0"
  },
  "devDependencies": {
    "typescript": "^5.7.0",
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
