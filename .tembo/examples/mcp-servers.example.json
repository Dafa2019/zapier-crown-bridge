{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "command": "npx",
      "args": ["@playwright/mcp-server", "--headless"]
    },
    "context7": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@upstash/context7-mcp"]
    },
    "internal-api": {
      "type": "http",
      "url": "https://internal-api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer ${INTERNAL_API_TOKEN}"
      }
    },
    "postgres": {
      "type": "http",
      "url": "https://postgres-mcp.example.com/mcp",
      "headers": {
        "Authorization": "Bearer ${DATABASE_URL}"
      }
    }
  }
}
